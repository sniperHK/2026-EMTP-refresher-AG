.DS_Store
**/.DS_Store

# Raw source materials (PDF/PPTX/etc.) and generated exports
# Keep folder-level README.md files tracked for structure documentation.
inputs/**
!inputs/README.md
exports/**
!exports/README.md
!exports/**/
!exports/**/manifest.md
references/raw/**
!references/raw/README.md

# Plaintext secrets - never commit
.env
.env.missing
.env.local
.env.*.local

# Dev-only local data stores
web/annotations.json
web/quiz-results.json

# age private key - never commit
age-key.txt

# Encrypted env files - safe to commit
!.env.age
!.env.*.age
